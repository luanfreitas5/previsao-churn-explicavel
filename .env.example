# =============================================================================
# .env.example — variáveis de ambiente (copie para .env e ajuste).
# NUNCA commite o .env. Apenas segredos/credenciais aqui; parâmetros ficam
# em configs/*.yaml.
# =============================================================================

# URI do servidor de tracking do MLflow (padrão: banco SQLite local).
# MLFLOW_TRACKING_URI=sqlite:///mlflow.db

# Exemplo de credencial (apenas se o projeto integrar serviços externos):
# KAGGLE_USERNAME=
# KAGGLE_KEY=
